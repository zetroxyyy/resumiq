#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase - NEVER commit these files
google-services.json
GoogleService-Info.plist
lib/firebase_options.dart

# API Keys and secrets - NEVER commit
.env
.env.local
.env.production
.env.development
.env.staging
*.key
secrets.json
api_keys.dart

# Flutter generated files
*.g.dart
*.freezed.dart

# pubspec.lock (libraries should not commit this)
pubspec.lock

# Firebase CLI cache
.firebase/
